// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ USERS ============
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("student") // student, teacher, admin
  avatar        String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  submissions        Submission[]
  progress           UserProgress[]
  notifications      Notification[]
  teacherClassrooms  Classroom[] @relation("TeacherClassrooms")
  studentClassrooms  ClassroomStudent[] @relation("StudentClassrooms")
}

// ============ CHAPTERS ============
model Chapter {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  icon        String   @default("fa-book")
  color       String   @default("#3B82F6")
  sortOrder   Int      @default(0)
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lessons     Lesson[]
}

// ============ LESSONS ============
model Lesson {
  id          String   @id @default(cuid())
  chapterId   String
  title       String
  slug        String?
  content     String?  @db.LongText
  duration    Int      @default(60)
  difficulty  String   @default("beginner")
  sortOrder   Int      @default(0)
  isLocked    Boolean  @default(false)
  isPublished Boolean  @default(true)
  
  // Learning Objectives
  objectiveKnowledge String? @db.Text
  objectiveSkills    String? @db.Text
  objectiveAttitude  String? @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  chapter     Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  sections    Section[]
  exercises   Exercise[]
  progress    UserProgress[]

  @@index([chapterId])
}

// ============ SECTIONS ============
model Section {
  id          String   @id @default(cuid())
  lessonId    String
  title       String
  content     String?  @db.LongText
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

// ============ EXERCISES ============
model Exercise {
  id            String   @id @default(cuid())
  lessonId      String
  type          String   @default("practice")
  title         String
  question      String?  @db.LongText
  answer        String?  @db.LongText
  difficulty    String   @default("easy")
  points        Int      @default(10)
  sortOrder     Int      @default(0)
  answerVisible Boolean  @default(false)
  dueDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  lesson        Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions   Submission[]

  @@index([lessonId])
}

// ============ SUBMISSIONS ============
model Submission {
  id          String   @id @default(cuid())
  exerciseId  String
  userId      String
  content     String   @db.LongText
  files       String?  @db.Text
  status      String   @default("pending")
  score       Int?
  maxScore    Int?
  feedback    String?  @db.Text
  gradedAt    DateTime?
  gradedBy    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@index([userId])
}

// ============ USER PROGRESS ============
model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean  @default(false)
  timeSpent   Int      @default(0)
  lastAccess  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

// ============ NOTIFICATIONS ============
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // submission_graded, new_submission, etc.
  title     String
  message   String   @db.Text
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============ CLASSROOMS ============
model Classroom {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  code        String   @unique // Mã lớp để học sinh tham gia
  teacherId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  teacher     User     @relation("TeacherClassrooms", fields: [teacherId], references: [id])
  students    ClassroomStudent[]

  @@index([teacherId])
}

model ClassroomStudent {
  id          String   @id @default(cuid())
  classroomId String
  studentId   String
  joinedAt    DateTime @default(now())

  // Relations
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student     User      @relation("StudentClassrooms", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
  @@index([classroomId])
  @@index([studentId])
}

// ============ SETTINGS ============
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ PASSWORD RESET (OTP) ============
model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  otp       String   // 6-digit numeric code
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
