// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ USERS ============
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("student") // student, teacher, admin
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  submissions                    Submission[]
  progress                       UserProgress[]
  lessonTabProgress              UserLessonTabProgress[]
  notifications                  Notification[]
  teacherClassrooms              Classroom[]                     @relation("TeacherClassrooms")
  studentClassrooms              ClassroomStudent[]              @relation("StudentClassrooms")
  profile                        StudentProfile?
  classroomAssignments           ClassroomAssignment[]           @relation("TeacherClassroomAssignments")
  classroomAssignmentSubmissions ClassroomAssignmentSubmission[] @relation("StudentAssignmentSubmissions")
  gradedClassroomSubmissions     ClassroomAssignmentSubmission[] @relation("TeacherAssignmentGradings")
}

// ============ CHAPTERS ============
model Chapter {
  id          String   @id @default(cuid())
  title       String
  description String?
  icon        String   @default("fa-book")
  color       String   @default("#3B82F6")
  sortOrder   Int      @default(0)
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lessons Lesson[]
}

// ============ LESSONS ============
model Lesson {
  id          String  @id @default(cuid())
  chapterId   String
  title       String
  slug        String?
  content     String? @db.Text
  duration    Int     @default(60)
  difficulty  String  @default("beginner")
  sortOrder   Int     @default(0)
  isLocked    Boolean @default(false)
  isPublished Boolean @default(true)

  // Learning Objectives
  objectiveKnowledge String? @db.Text
  objectiveSkills    String? @db.Text
  objectiveAttitude  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  chapter     Chapter                 @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  sections    Section[]
  exercises   Exercise[]
  progress    UserProgress[]
  tabProgress UserLessonTabProgress[]
  assignments ClassroomAssignment[]
  milestoneLinks MilestoneLesson[]
  outcomeLinks   OutcomeLesson[]

  @@index([chapterId])
}

// ============ SECTIONS ============
model Section {
  id        String   @id @default(cuid())
  lessonId  String
  title     String
  content   String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

// ============ EXERCISES ============
model Exercise {
  id            String    @id @default(cuid())
  lessonId      String
  type          String    @default("practice")
  title         String
  question      String?   @db.Text
  answer        String?   @db.Text
  difficulty    String    @default("easy")
  points        Int       @default(10)
  sortOrder     Int       @default(0)
  answerVisible Boolean   @default(false)
  dueDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([lessonId])
}

// ============ SUBMISSIONS ============
model Submission {
  id         String    @id @default(cuid())
  exerciseId String
  userId     String
  content    String    @db.Text
  files      String?   @db.Text
  status     String    @default("pending")
  score      Float?
  maxScore   Int?
  feedback   String?   @db.Text
  gradedAt   DateTime?
  gradedBy   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@index([userId])
}

// ============ USER PROGRESS ============
model UserProgress {
  id         String   @id @default(cuid())
  userId     String
  lessonId   String
  completed  Boolean  @default(false)
  timeSpent  Int      @default(0)
  lastAccess DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model UserLessonTabProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  tabId       String
  completed   Boolean   @default(false)
  timeSpent   Int       @default(0)
  lastAccess  DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId, tabId])
  @@index([userId, lessonId])
  @@index([lessonId])
}

// ============ NOTIFICATIONS ============
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // submission_graded, new_submission, etc.
  title     String
  message   String   @db.Text
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============ CLASSROOMS ============
model Classroom {
  id          String   @id @default(cuid())
  name        String
  description String?
  code        String   @unique // Mã lớp để học sinh tham gia
  teacherId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  teacher     User                  @relation("TeacherClassrooms", fields: [teacherId], references: [id])
  students    ClassroomStudent[]
  assignments ClassroomAssignment[]

  @@index([teacherId])
}

model ClassroomStudent {
  id          String   @id @default(cuid())
  classroomId String
  studentId   String
  joinedAt    DateTime @default(now())

  // Relations
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation("StudentClassrooms", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
  @@index([classroomId])
  @@index([studentId])
}

// ============ STUDENT PROFILES ============
model StudentProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  age        Int?
  gender     String?
  gradeLevel String?
  school     String?
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ CLASSROOM ASSIGNMENTS ============
model ClassroomAssignment {
  id              String   @id @default(cuid())
  classroomId     String
  lessonId        String?
  title           String
  description     String?
  type            String   @default("homework") // homework, test
  durationMinutes Int?
  questionHtml    String?  @db.Text
  questionDocx    String?  @db.Text
  answerTemplate  String?  @db.Text
  maxScore        Int      @default(10)
  isPublished     Boolean  @default(true)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  classroom   Classroom                       @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  lesson      Lesson?                         @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  teacher     User?                           @relation("TeacherClassroomAssignments", fields: [createdBy], references: [id], onDelete: SetNull)
  submissions ClassroomAssignmentSubmission[]

  @@index([classroomId])
  @@index([lessonId])
  @@index([type])
  @@index([createdBy])
}

model ClassroomAssignmentSubmission {
  id           String    @id @default(cuid())
  assignmentId String
  studentId    String
  content      String    @db.Text
  status       String    @default("submitted") // submitted, graded
  score        Float?
  feedback     String?   @db.Text
  gradedAt     DateTime?
  gradedBy     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  assignment ClassroomAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User                @relation("StudentAssignmentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  grader     User?               @relation("TeacherAssignmentGradings", fields: [gradedBy], references: [id], onDelete: SetNull)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([gradedBy])
}

// ============ SETTINGS ============
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ PASSWORD RESET (OTP) ============
model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  otp       String // 6-digit numeric code
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ============ TRAINING PROGRAM META LAYER ============
model Program {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  milestones Milestone[]
  skills     Skill[]

  @@index([isActive])
  @@index([sortOrder])
}

model Milestone {
  id          String   @id @default(cuid())
  programId   String
  title       String
  description String?  @db.Text
  icon        String   @default("fa-flag-checkered")
  color       String   @default("#3B82F6")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program  Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  lessons  MilestoneLesson[]
  outcomes LearningOutcome[]

  @@index([programId])
  @@index([programId, sortOrder])
}

model MilestoneLesson {
  id          String   @id @default(cuid())
  milestoneId String
  lessonId    String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([milestoneId, lessonId])
  @@index([lessonId])
  @@index([milestoneId, sortOrder])
}

model LearningOutcome {
  id          String   @id @default(cuid())
  milestoneId String
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  milestone Milestone      @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  lessons   OutcomeLesson[]
  skills    OutcomeSkill[]

  @@index([milestoneId])
  @@index([milestoneId, sortOrder])
}

model OutcomeLesson {
  id        String   @id @default(cuid())
  outcomeId String
  lessonId  String
  createdAt DateTime @default(now())

  outcome LearningOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  lesson  Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([outcomeId, lessonId])
  @@index([lessonId])
}

model Skill {
  id            String   @id @default(cuid())
  programId     String
  parentSkillId String?
  title         String
  description   String?  @db.Text
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  program      Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  parentSkill  Skill?         @relation("SkillTree", fields: [parentSkillId], references: [id], onDelete: SetNull)
  childSkills  Skill[]        @relation("SkillTree")
  outcomeLinks OutcomeSkill[]

  @@index([programId])
  @@index([parentSkillId])
  @@index([programId, sortOrder])
}

model OutcomeSkill {
  id        String   @id @default(cuid())
  outcomeId String
  skillId   String
  createdAt DateTime @default(now())

  outcome LearningOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  skill   Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([outcomeId, skillId])
  @@index([skillId])
}
