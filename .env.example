# Database - MySQL (iNET Cloud Hosting)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://username:password@host:3306/database_name"

# Session Secret (tạo chuỗi ngẫu nhiên)
SESSION_SECRET="your-random-secret-key-here-32-chars-min"

# Email / SMTP (dùng để gửi OTP đặt lại mật khẩu)
# Để trống → OTP chỉ in ra console (chế độ dev)
# Gmail: bật "App Password" tại https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM='"Python LMS" <your-email@gmail.com>'

# Google Gemini AI (dùng để tạo bài giảng tự động)
GEMINI_API_KEY="your-gemini-api-key"
