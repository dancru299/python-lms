# Database - MySQL (iNET Cloud Hosting)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://username:password@host:3306/database_name"

# Session secret
SESSION_SECRET="your-random-secret-key-here-32-chars-min"

# Email / SMTP for password reset OTP
# Leave SMTP_USER and SMTP_PASS empty to print OTP in the dev console.
# Gmail requires an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM='"Python LMS" <your-email@gmail.com>'

# AI lesson generation
# Default provider: gemini | openai | openrouter | groq | deepseek | qwen
AI_DEFAULT_PROVIDER="gemini"

# Provider API keys
GEMINI_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
GROQ_API_KEY=""
DEEPSEEK_API_KEY=""
QWEN_API_KEY=""
# DASHSCOPE_API_KEY=""

# Optional model overrides
AI_GEMINI_MODEL="gemini-2.5-flash"
AI_OPENAI_MODEL="gpt-5.2"
AI_OPENROUTER_MODEL="openai/gpt-5.2"
AI_GROQ_MODEL="openai/gpt-oss-120b"
AI_DEEPSEEK_MODEL="deepseek-reasoner"
AI_QWEN_MODEL="qwen3.5-plus"

# Optional OpenRouter / Qwen extras
# OPENROUTER_HTTP_REFERER="https://your-app.example.com"
# OPENROUTER_APP_NAME="python-lms"
# QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
