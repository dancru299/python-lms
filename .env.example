# Database - Supabase Postgres
# Runtime/serverless connection: Supavisor transaction pooler, port 6543.
# Add ?pgbouncer=true so Prisma works with transaction pooling.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Migration/admin connection: Supavisor session pooler, port 5432.
# Prisma Migrate uses this for schema changes.
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Supabase Storage for lesson images
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="lesson-media"

# Session secret
SESSION_SECRET="your-random-secret-key-here-32-chars-min"

# Email / SMTP for password reset OTP
# Leave SMTP_USER and SMTP_PASS empty to print OTP in the dev console.
# Gmail requires an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM='"Python LMS" <your-email@gmail.com>'

# AI lesson generation
# Default provider: gemini | openai | openrouter | groq | deepseek | qwen
AI_DEFAULT_PROVIDER="gemini"

# Provider API keys
GEMINI_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
GROQ_API_KEY=""
DEEPSEEK_API_KEY=""
QWEN_API_KEY=""
# DASHSCOPE_API_KEY=""

# Optional model overrides
AI_GEMINI_MODEL="gemini-2.5-flash"
AI_OPENAI_MODEL="gpt-5.2"
AI_OPENROUTER_MODEL="openai/gpt-5.2"
AI_GROQ_MODEL="openai/gpt-oss-120b"
AI_DEEPSEEK_MODEL="deepseek-reasoner"
AI_QWEN_MODEL="qwen3.5-plus"

# Optional OpenRouter / Qwen extras
# OPENROUTER_HTTP_REFERER="https://your-app.example.com"
# OPENROUTER_APP_NAME="python-lms"
# QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
